APP_NAME=OnboardKit Mailroom
NEXT_PUBLIC_APP_URL=http://localhost:3000
EMAIL_DOMAIN=onboardkit.pro

# Generate with: pnpm hash-password "your-password"
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Resend inbound email receiving
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Cloudflare R2 for permanent attachment storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional
ALLOW_DEMO_INGEST=true
AUTO_CREATE_ON_RECEIVE=false
